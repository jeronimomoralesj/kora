# ── Dependencies ──────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*

# ── Next.js build output ──────────────────────────────────────
/.next/
/out/
/build
next-env.d.ts

# ── Production HD photography ─────────────────────────────────
# Real, high-resolution KORA product/recipe photography is heavy and
# licensed — it is NOT committed to source control. Drop approved assets
# into the folder below following the spec in /app/image-format.
# The app ships with lightweight committed placeholders so it always runs.
# See: app/image-format/page.js  and  public/photography/README.md
/public/photography/raw/
/public/photography/hd/
*.psd
*.tiff

# ── Environment / secrets ─────────────────────────────────────
.env
.env*.local

# ── Misc / OS ─────────────────────────────────────────────────
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.vercel
*.tsbuildinfo
